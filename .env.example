# Client (Vite — safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_VAPID_PUBLIC_KEY=BNx...
# Shown in Privacy policy (optional — defaults to support@nutrilog.app)
# VITE_SUPPORT_EMAIL=you@yourdomain.com
# VITE_LEGAL_ENTITY=Your Company Ltd

# Server only (Netlify dashboard — never commit real keys)
GEMINI_API_KEY=AIza...
GEMINI_VISION_MODEL=gemini-3.1-flash-lite
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite

# One code (legacy) OR several codes — use VOUCHER_CODES for multiple promos
VOUCHER_CODE=NUTRIPROMO
VOUCHER_EXPIRES=2027-07-16
# VOUCHER_CODES=NUTRIPROMO:2027-07-16:discount,TRIAL7:2026-12-31:trial:daily10:7,TRYPLUS:2026-12-31:trial:daily25:14
# Trial format: CODE:YYYY-MM-DD:trial:daily10|daily25:DAYS
# Built-in defaults (no env): NUTRIPROMO (30% off), TRIAL7 (7-day Standard), TRYPLUS (14-day Plus)

STRIPE_SECRET_KEY=sk_test_...
STRIPE_DAILY10_PRICE_ID=price_...
STRIPE_DAILY10_DISCOUNT_PRICE_ID=price_...
STRIPE_DAILY25_PRICE_ID=price_...
STRIPE_DAILY25_DISCOUNT_PRICE_ID=price_...
STRIPE_TOPUP_PRICE_ID=price_...
STRIPE_TOPUP_DISCOUNT_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_
STRIPE_WEBHOOK_SECRET=whsec_...

VAPID_PUBLIC_KEY=BNx...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=mailto:REPLACE_ME@example.com

SUPABASE_URL=https://your-project.supabase.co
