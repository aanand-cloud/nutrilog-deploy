{
  "name": "nutrilog",
  "version": "0.2.0",
  "description": "Photo-first calorie and nutrition tracker — worldwide, multi-cuisine",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:https": "vite --host --mode https",
    "build": "node scripts/generate-icons.mjs && vite build",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "supabase:setup": "node scripts/setup-supabase.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor/camera": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/local-notifications": "^7.0.1",
    "@supabase/supabase-js": "^2.49.8",
    "heic2any": "^0.0.4",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/cli": "^7.2.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "stripe": "^17.7.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.21.1"
  }
}
